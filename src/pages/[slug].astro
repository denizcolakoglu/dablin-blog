---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

type Props = { post: CollectionEntry<'posts'> };
const { post } = Astro.props;
const { Content } = await post.render();

const COVER_IMAGES: Record<string, string> = {
  'what-is-dablin': '/images/what-is-dablin.png',
  'backlink-quality-vs-quantity': '/images/backlink-quality-vs-quantity.png',
  'google-march-2026-update': '/images/google-march-2026-update.png',
  'ai-visibility-problem-solo-entrepreneurs': '/images/ai-visibility-problem-solo-entrepreneurs.png',
  'information-gain-google-march-2026': '/images/information-gain-google-march-2026.png',
};

const coverImage = COVER_IMAGES[post.slug];
const ogImage = coverImage
  ? `https://blog.dablin.co${coverImage}`
  : 'https://dablin.co/og-image.png';

const postUrl = `https://blog.dablin.co/${post.slug}`;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.data.title,
  "description": post.data.description,
  "url": postUrl,
  "datePublished": new Date(post.data.date).toISOString(),
  "dateModified": new Date(post.data.date).toISOString(),
  "author": {
    "@type": "Organization",
    "name": "Dablin",
    "url": "https://dablin.co"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Dablin",
    "url": "https://dablin.co",
    "logo": {
      "@type": "ImageObject",
      "url": "https://dablin.co/logo.svg"
    }
  },
  "image": ogImage,
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": postUrl
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://dablin.co"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Blog",
      "item": "https://blog.dablin.co"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": post.data.title,
      "item": postUrl
    }
  ]
};

const formattedDate = new Date(post.data.date).toLocaleDateString('en-GB', { day:'numeric', month:'long', year:'numeric' });
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={ogImage}
  url={postUrl}
  type="article"
  articleSchema={articleSchema}
  breadcrumbSchema={breadcrumbSchema}
>
  <style>
    .post-hero { background:#ffffff; border-bottom:1px solid #e8ede8; padding:52px 48px 44px; }
    .post-hero-inner { max-width:720px; margin:0 auto; }
    .post-tags { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:18px; }
    .post-tag { font-size:11px; font-weight:600; background:#eef5ee; color:#2d6a2d; border-radius:100px; padding:4px 12px; }
    .post-title { font-size:36px; font-weight:800; color:#1a2e1a; line-height:1.2; margin:0 0 20px; letter-spacing:-0.5px; }
    .post-meta-row { display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px; }
    .post-meta-left { display:flex; align-items:center; gap:10px; font-size:13px; color:#a09a94; }
    .post-meta-dot { color:#ddd; }
    .share-btn { display:flex; align-items:center; gap:6px; font-size:13px; font-weight:600; color:#2d6a2d; background:#eef5ee; border:1px solid #c8e0c8; padding:8px 16px; border-radius:8px; cursor:pointer; font-family:'Roboto',sans-serif; transition:all 0.15s; }
    .share-btn:hover { background:#d8ecd8; }
    .post-cover { max-width:720px; margin:0 auto; padding:32px 24px 0; }
    .post-cover img { width:100%; border-radius:12px; aspect-ratio:16/9; object-fit:cover; display:block; }
    .post-body { max-width:720px; margin:0 auto; padding:48px 24px; }
    .prose h2 { font-size:22px; font-weight:800; color:#1a2e1a; margin:32px 0 12px; letter-spacing:-0.5px; }
    .prose h3 { font-size:18px; font-weight:700; color:#1a2e1a; margin:24px 0 10px; }
    .prose p { font-size:16px; color:#3a4a3a; line-height:1.8; margin-bottom:18px; font-weight:300; }
    .prose ul, .prose ol { padding-left:24px; margin-bottom:18px; }
    .prose li { font-size:16px; color:#3a4a3a; line-height:1.8; margin-bottom:6px; font-weight:300; }
    .prose strong { font-weight:700; color:#1a2e1a; }
    .prose em { font-style:italic; color:#6b6560; }
    .prose a { color:#2d6a2d; text-decoration:underline; }
    .prose blockquote { border-left:3px solid #2d6a2d; padding-left:16px; margin:24px 0; color:#6b6560; font-style:italic; }
    .prose hr { border:none; border-top:1px solid #dde8dd; margin:32px 0; }
    .prose code { background:#eaf3ea; color:#1a2e1a; padding:2px 6px; border-radius:4px; font-size:14px; }
    .cta-box { background:#0f2a1a; border-radius:16px; padding:28px 32px; margin:48px 0; display:flex; align-items:center; justify-content:space-between; gap:24px; }
    .cta-box-text { flex:1; }
    .cta-eyebrow { font-size:11px; font-weight:500; letter-spacing:0.08em; text-transform:uppercase; color:rgba(255,255,255,0.4); margin-bottom:6px; }
    .cta-title { font-size:18px; font-weight:700; color:#ffffff; line-height:1.3; margin-bottom:8px; }
    .cta-desc { font-size:13px; color:rgba(255,255,255,0.55); line-height:1.5; margin:0; }
    .cta-btn { display:inline-block; flex-shrink:0; padding:12px 20px; background:#2d7a3a; color:#fff; border:none; border-radius:10px; font-size:14px; font-weight:600; cursor:pointer; font-family:'Roboto',sans-serif; text-decoration:none; white-space:nowrap; }
    .cta-btn:hover { background:#3a9a4a; }
    .post-footer { border-top:1px solid #dde8dd; padding-top:28px; margin-top:8px; display:flex; align-items:center; justify-content:space-between; margin-bottom:40px; }
    .post-footer-meta { font-size:13px; color:#a09a94; }
    .share-btn-bottom { display:flex; align-items:center; gap:6px; font-size:13px; font-weight:600; color:#2d6a2d; background:#eef5ee; border:1px solid #c8e0c8; padding:9px 18px; border-radius:8px; cursor:pointer; font-family:'Roboto',sans-serif; transition:all 0.15s; }
    .share-btn-bottom:hover { background:#d8ecd8; }
    @media(max-width:600px){ .cta-box { flex-direction:column; align-items:flex-start; } }
    @media(max-width:768px){ .post-hero { padding:40px 24px 32px; } .post-title { font-size:28px; } }
  </style>

  <!-- HERO -->
  <div class="post-hero">
    <div class="post-hero-inner">
      <div class="post-tags">
        {(post.data.tags || []).map(tag => (
          <span class="post-tag">{tag}</span>
        ))}
      </div>
      <h1 class="post-title">{post.data.title}</h1>
      <div class="post-meta-row">
        <div class="post-meta-left">
          <span>Dablin</span>
          <span class="post-meta-dot">·</span>
          <span>{formattedDate}</span>
          <span class="post-meta-dot">·</span>
          <span>5 min read</span>
        </div>
        <button class="share-btn" onclick={`navigator.clipboard.writeText('${postUrl}').then(()=>{this.textContent='✓ Copied!';setTimeout(()=>this.textContent='Share',2000)})`}>
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
          Share
        </button>
      </div>
    </div>
  </div>

  <!-- COVER IMAGE -->
  {coverImage && (
    <div class="post-cover">
      <img src={coverImage} alt={post.data.title} />
    </div>
  )}

  <!-- ARTICLE BODY -->
  <div class="post-body">
    <div class="prose">
      <Content />
    </div>

    <!-- CTA -->
    <div class="cta-box">
      <div class="cta-box-text">
        <p class="cta-eyebrow">Free tool by Dablin</p>
        <p class="cta-title">Is your brand visible to AI?</p>
        <p class="cta-desc">Check if ChatGPT, Gemini, and Claude mention you. Free, results in 20 seconds.</p>
      </div>
      <a href="https://dablin.co" class="cta-btn">Try Dablin →</a>
    </div>

    <!-- FOOTER ROW -->
    <div class="post-footer">
      <span class="post-footer-meta">{formattedDate} · Dablin</span>
      <button class="share-btn-bottom"
        onclick={`navigator.clipboard.writeText('${postUrl}').then(()=>{this.textContent='✓ Copied!';setTimeout(()=>this.textContent='Share',2000)})`}>
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
        Share
      </button>
    </div>
  </div>
</BaseLayout>
